# =====================================================
# Ejemplo de variables de entorno (no es obligatorio usarlo)
# Copia este archivo como .env y ajusta los valores.
# =====================================================

# ---- Backend (Node/Express) ----
# Puerto donde corre el servidor
PORT=3000

# Opcional: orígenes permitidos para CORS (coma-separados)
# CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ---- Firebase Admin (opcional, si usas firebase-admin) ----
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# Nota: si pegas una private key con saltos de línea,
# respétalos tal cual en el .env (a veces vienen con \n).

